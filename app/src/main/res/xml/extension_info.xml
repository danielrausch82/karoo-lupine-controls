<?xml version="1.0" encoding="utf-8"?>
<ExtensionInfo
    id="karoo-lupine-controls"
    displayName="@string/app_name"
    icon="@drawable/ic_lupine_launcher"
    scansDevices="false">

    <DataType
        typeId="DATATYPE_LIGHT_CONTROLS"
        displayName="@string/field_light_controls"
        description="@string/field_light_controls_desc"
        icon="@drawable/ic_lupine_compact"
        graphical="true" />

    <BonusAction actionId="lamp-off" displayName="@string/action_light_off" />
    <BonusAction actionId="low-beam" displayName="@string/action_light_10" />
    <BonusAction actionId="high-beam" displayName="@string/action_light_100" />
</ExtensionInfo>
